# =============================================
# 개발 환경 전용 설정 (npm run dev)
# 커밋 가능 — 민감 정보 포함 금지
# =============================================

# 개발 서버 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 개발 중 빠른 반영을 위해 ISR 주기 단축
NEXT_PUBLIC_REVALIDATE_SECONDS=10

# 개발 환경 식별 (NEXT_PUBLIC_ 없이 쓰면 서버 사이드 전용)
APP_ENV=development
