# =============================================
# 공통 환경변수 (개발/운영 공통 적용)
# 커밋 가능 — 민감 정보 포함 금지
# =============================================

# 사이트 기본 정보
NEXT_PUBLIC_SITE_NAME=북 리뷰

# ISR 재생성 주기 (초) — .env.development/.env.production에서 덮어쓰기 가능
NEXT_PUBLIC_REVALIDATE_SECONDS=60

# 연간 독서 목표 권수
NEXT_PUBLIC_YEARLY_GOAL=50
