# =============================================
# 운영 환경 전용 설정 (npm run build / Vercel)
# 커밋 가능 — 민감 정보 포함 금지
# =============================================

# 배포 후 실제 도메인으로 변경
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# 운영은 60초 ISR 유지
NEXT_PUBLIC_REVALIDATE_SECONDS=60

# 운영 환경 식별
APP_ENV=production
